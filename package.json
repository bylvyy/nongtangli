{
  "name": "shanghai-citywalk",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "precompute": "node scripts/precompute-walking.mjs",
    "prebuild": "node scripts/precompute-walking.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:migrate:local": "wrangler d1 migrations apply nongtangli --local",
    "db:migrate:remote": "wrangler d1 migrations apply nongtangli --remote",
    "db:seed:local": "node scripts/seed-d1.mjs --local",
    "db:seed:remote": "node scripts/seed-d1.mjs --remote",
    "pages:dev": "npm run build && wrangler pages dev out --compatibility-date=2024-09-23"
  },
  "dependencies": {
    "next": "14.2.5",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "leaflet": "1.9.4",
    "react-leaflet": "4.2.1"
  },
  "devDependencies": {
    "autoprefixer": "10.4.19",
    "postcss": "8.4.39",
    "tailwindcss": "3.4.4",
    "@types/leaflet": "1.9.12",
    "wrangler": "^3.78.0"
  }
}
